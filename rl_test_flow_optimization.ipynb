    "def evaluate_q_learning(env, agent, num_episodes=100):\n",
    "    \"\"\"\n",
    "    Evaluate trained Q-Learning agent (no exploration)\n",
    "    \n",
    "    Args:\n",
    "        env: Test flow environment\n",
    "        agent: Trained Q-Learning agent\n",
    "        num_episodes: Number of evaluation episodes\n",
    "    \n",
    "    Returns:\n",
    "        Evaluation statistics\n",
    "    \"\"\"\n",
    "    # Save original epsilon and set to 0 (no exploration)\n",
    "    original_epsilon = agent.epsilon\n",
    "    agent.epsilon = 0.0\n",
    "    \n",
    "    episode_rewards = []\n",
    "    episode_costs = []\n",
    "    episode_tests = []\n",
    "    detection_rate = []\n",
    "    \n",
    "    for episode in range(num_episodes):\n",
    "        state = env.reset()\n",
    "        total_reward = 0\n",
    "        done = False\n",
    "        \n",
    "        while not done:\n",
    "            # Greedy action selection (best Q-value)\n",
    "            available_actions = env.get_available_actions()\n",
    "            action = agent.select_action(state, available_actions)\n",
    "            next_state, reward, done, info = env.step(action)\n",
    "            \n",
    "            state = next_state\n",
    "            total_reward += reward\n",
    "        \n",
    "        episode_rewards.append(total_reward)\n",
    "        episode_costs.append(env.total_cost)\n",
    "        episode_tests.append(np.sum(env.tests_performed))\n",
    "        detection_rate.append(1 if env.defect_detected else 0)\n",
    "    \n",
    "    # Restore original epsilon\n",
    "    agent.epsilon = original_epsilon\n",
    "    \n",
    "    return {\n",
    "        'rewards': episode_rewards,\n",
    "        'costs': episode_costs,\n",
    "        'tests': episode_tests,\n",
    "        'detection_rate': detection_rate\n",
    "    }\n",
    "\n",
    "print(\"✓ Q-Learning evaluation function defined\")"
   ]
  },
