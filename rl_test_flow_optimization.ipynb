   "source": [
    "## Part 4: Q-Learning Algorithm\n",
    "\n",
    "**Q-Learning** is a fundamental RL algorithm that learns the quality (Q-value) of taking each action in each state.\n",
    "\n",
    "### Q-Learning Fundamentals\n",
    "\n",
    "**Q-Value** Q(s, a) represents the expected cumulative reward of taking action `a` in state `s` and following the optimal policy thereafter.\n",
    "\n",
    "**Q-Learning Update Rule:**\n",
    "\n",
    "```\n",
    "Q(s, a) ← Q(s, a) + α × [r + γ × max Q(s', a') - Q(s, a)]\n",
    "```\n",
    "\n",
    "Where:\n",
    "- **α (alpha)**: Learning rate (how much to update Q-values)\n",
    "- **γ (gamma)**: Discount factor (importance of future rewards)\n",
    "- **r**: Immediate reward\n",
    "- **s'**: Next state\n",
    "- **max Q(s', a')**: Maximum Q-value for next state\n",
    "\n",
    "### Exploration vs Exploitation\n",
    "\n",
    "**ε-greedy strategy**: With probability ε, explore (random action); otherwise, exploit (best known action)\n",
    "\n",
    "This balances learning new strategies (exploration) with using known good strategies (exploitation)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class QLearningAgent:\n",
    "    \"\"\"\n",
    "    Q-Learning Agent for Test Flow Optimization\n",
    "    \n",
    "    Uses tabular Q-learning with epsilon-greedy exploration\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, num_actions, learning_rate=0.1, discount_factor=0.95, \n",
    "                 epsilon=1.0, epsilon_decay=0.995, epsilon_min=0.01):\n",
    "        \"\"\"\n",
    "        Initialize Q-Learning agent\n",
    "        \n",
    "        Args:\n",
    "            num_actions: Number of possible actions\n",
    "            learning_rate (α): How much to update Q-values (0-1)\n",
    "            discount_factor (γ): Importance of future rewards (0-1)\n",
    "            epsilon (ε): Initial exploration rate (0-1)\n",
    "            epsilon_decay: Rate at which epsilon decreases\n",
    "            epsilon_min: Minimum epsilon value\n",
    "        \"\"\"\n",
    "        self.num_actions = num_actions\n",
    "        self.learning_rate = learning_rate\n",
    "        self.discount_factor = discount_factor\n",
    "        self.epsilon = epsilon\n",
    "        self.epsilon_decay = epsilon_decay\n",
    "        self.epsilon_min = epsilon_min\n",
    "        \n",
    "        # Q-table: dictionary mapping (state, action) to Q-value\n",
    "        self.q_table = defaultdict(lambda: np.zeros(num_actions))\n",
    "        \n",
    "    def state_to_key(self, state):\n",
    "        \"\"\"Convert state array to hashable key for Q-table\"\"\"\n",
    "        return tuple(state)\n",
    "    \n",
    "    def select_action(self, state, available_actions):\n",
    "        \"\"\"\n",
    "        Select action using epsilon-greedy strategy\n",
    "        \n",
    "        Args:\n",
    "            state: Current state\n",
    "            available_actions: List of valid actions\n",
    "        \n",
    "        Returns:\n",
    "            Selected action\n",
    "        \"\"\"\n",
    "        # Exploration: random action\n",
    "        if np.random.random() < self.epsilon:\n",
    "            return np.random.choice(available_actions)\n",
    "        \n",
    "        # Exploitation: best known action\n",
    "        state_key = self.state_to_key(state)\n",
    "        q_values = self.q_table[state_key]\n",
    "        \n",
    "        # Get Q-values for available actions only\n",
    "        available_q_values = [(action, q_values[action]) for action in available_actions]\n",
    "        best_action = max(available_q_values, key=lambda x: x[1])[0]\n",
    "        \n",
    "        return best_action\n",
    "    \n",
    "    def update(self, state, action, reward, next_state, done):\n",
    "        \"\"\"\n",
    "        Update Q-value using Q-learning update rule\n",
    "        \n",
    "        Q(s,a) ← Q(s,a) + α[r + γ max Q(s',a') - Q(s,a)]\n",
    "        \"\"\"\n",
    "        state_key = self.state_to_key(state)\n",
    "        next_state_key = self.state_to_key(next_state)\n",
    "        \n",
    "        # Current Q-value\n",
    "        current_q = self.q_table[state_key][action]\n",
    "        \n",
    "        # Maximum Q-value for next state\n",
    "        if done:\n",
    "            max_next_q = 0  # No future rewards if episode is done\n",
    "        else:\n",
    "            max_next_q = np.max(self.q_table[next_state_key])\n",
    "        \n",
    "        # Q-learning update\n",
    "        new_q = current_q + self.learning_rate * (reward + self.discount_factor * max_next_q - current_q)\n",
    "        self.q_table[state_key][action] = new_q\n",
    "    \n",
    "    def decay_epsilon(self):\n",
    "        \"\"\"Decrease exploration rate over time\"\"\"\n",
    "        self.epsilon = max(self.epsilon_min, self.epsilon * self.epsilon_decay)\n",
    "\n",
    "print(\"✓ QLearningAgent class defined\")\n",
    "print(\"\\nKey Methods:\")\n",
    "print(\"  - select_action(): Choose action using ε-greedy\")\n",
    "print(\"  - update(): Update Q-values based on experience\")\n",
    "print(\"  - decay_epsilon(): Reduce exploration over time\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Training the Q-Learning Agent\n",
    "\n",
    "Now we'll train the Q-Learning agent over multiple episodes. Each episode represents testing one chip from start to finish."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_q_learning(env, agent, num_episodes=1000, verbose=True):\n",
    "    \"\"\"\n",
    "    Train Q-Learning agent\n",
    "    \n",
    "    Args:\n",
    "        env: Test flow environment\n",
    "        agent: Q-Learning agent\n",
    "        num_episodes: Number of training episodes\n",
    "        verbose: Print progress\n",
    "    \n",
    "    Returns:\n",
    "        Training statistics\n",
    "    \"\"\"\n",
    "    episode_rewards = []\n",
    "    episode_costs = []\n",
    "    episode_tests = []\n",
    "    detection_rate = []\n",
    "    \n",
    "    for episode in range(num_episodes):\n",
    "        state = env.reset()\n",
    "        total_reward = 0\n",
    "        done = False\n",
    "        \n",
    "        while not done:\n",
    "            # Select and perform action\n",
    "            available_actions = env.get_available_actions()\n",
    "            action = agent.select_action(state, available_actions)\n",
    "            next_state, reward, done, info = env.step(action)\n",
    "            \n",
    "            # Update Q-values\n",
    "            agent.update(state, action, reward, next_state, done)\n",
    "            \n",
    "            state = next_state\n",
    "            total_reward += reward\n",
    "        \n",
    "        # Decay exploration rate\n",
    "        agent.decay_epsilon()\n",
    "        \n",
    "        # Record statistics\n",
    "        episode_rewards.append(total_reward)\n",
    "        episode_costs.append(env.total_cost)\n",
    "        episode_tests.append(np.sum(env.tests_performed))\n",
    "        detection_rate.append(1 if env.defect_detected else 0)\n",
    "        \n",
    "        # Print progress\n",
    "        if verbose and (episode + 1) % 100 == 0:\n",
