# ============================================================================
# Environment Configuration - rl-test-flow-optimization
# ============================================================================

# ---- RL Training ----
ALGORITHM=maskable_ppo  # maskable_ppo, ppo, dqn, a2c
TIMESTEPS=50000
N_TESTS=10
SEED=42

# ---- Data ----
DATA_DIR=data
DATASET_PATH=data/chip_test_data.parquet
N_CHIPS=1000000
DEFECT_RATE=0.70

# ---- Training ----
LEARNING_RATE=3e-4
BATCH_SIZE=64
N_ENVS=8
N_STEPS=2048

# ---- Experiment Tracking ----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rl_test_flow
WANDB_API_KEY=
WANDB_PROJECT=rl-test-flow

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
MODEL_CHECKPOINT=models/best_model.zip

# ---- Optuna HPO ----
OPTUNA_N_TRIALS=30
OPTUNA_STORAGE=sqlite:///optuna.db
